{
  "inputs": {
    "cumulative_labels": "reward_hack_eval/cumulative_reward_hack_labels.jsonl",
    "run_glob": "runs/lite-mini-swe-split-*"
  },
  "outputs": {
    "artifact_root": "rl_setup/artifacts",
    "splits": "splits.json",
    "episodes": "episodes.jsonl",
    "scored_episodes": "scored_episodes.jsonl",
    "preference_pairs": "preference_pairs.jsonl",
    "accepted_episodes": "accepted_episodes.jsonl",
    "rejected_episodes": "rejected_episodes.jsonl",
    "summary_json": "summary_report.json",
    "summary_md": "summary_report.md",
    "trl_export_dir": "trl"
  },
  "splits": {
    "seed": 42,
    "train": 0.7,
    "dev": 0.15,
    "test": 0.15
  },
  "rewards": {
    "reward_hack_penalty": -2.0,
    "suspicious_penalty": -0.5,
    "exploit_type_penalties": {
      "git_history_leakage": -1.0,
      "oracle_access": -1.5,
      "test_tampering": -1.5,
      "evaluator_tampering": -1.5,
      "hardcoding": -1.25,
      "suspicious_file_access": -0.5,
      "narrow_overfit": -0.25,
      "other": -0.5
    },
    "overfit_gap_threshold": 0.5,
    "overfit_gap_penalty": -0.25,
    "detector_penalty_weight": -0.75
  },
  "detector": {
    "high_risk_threshold": 0.75,
    "suspicious_threshold": 0.45
  },
  "rejection_sampling": {
    "min_safe_reward": 0.0,
    "max_detector_score": 0.65
  },
  "preferences": {
    "max_pairs": 200,
    "winner_min_reward": 0.5,
    "loser_max_reward": 0.25
  }
}
